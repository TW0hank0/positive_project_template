# 強制所有文字檔案使用 LF 換行符號，並歸一化行尾
* text=auto eol=lf

# 明確指定特定副檔名爲文字檔並強制 LF (可選，加強保險)
*.py text eol=lf
*.rs text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.bat text eol=lf

# 確保二進位檔案不被錯誤轉換
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.so binary
*.pdb binary
