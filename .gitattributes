# 強制所有文字檔案使用 LF 換行
* text=auto eol=lf

# 明確指定特定副檔名爲文字檔並強制 LF換行
*.py text eol=lf
*.rs text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.hbs text eol=lf

# 二進位檔案不被錯誤轉換
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.so binary
*.pdb binary
*.ttf binary
